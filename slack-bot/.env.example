# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-xxxx

# Firebase Service Account JSON codificado em base64
# Gerar com: base64 -w0 stockflow-*.json  (Linux/Mac)
#        ou: [Convert]::ToBase64String([IO.File]::ReadAllBytes("stockflow-*.json"))  (PowerShell)
FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoi...

# Mapeamento stockistId -> Slack Member ID (JSON)
STOCKIST_SLACK_MAP={"joao_victor":"U08762E1PMM","roberia_gilo":"U08B1MQJL3C","pedro_lucas":"U09BMRBFRM0"}

# (Opcional) Se definido, TODAS as mensagens vao para esse ID (para teste)
TEST_SLACK_ID=

# (Opcional) Secret para proteger o endpoint /send-summary
API_SECRET=

# Fuso horario em horas vs UTC (Alagoas = -3)
TIMEZONE_OFFSET=-3

# Porta (Render define automaticamente)
PORT=3000
